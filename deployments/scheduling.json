    },
    "name": "scheduling",
    "namespace": "dev-ben"
  },
  "spec": {
    "progressDeadlineSeconds": 600,
    "replicas": 1,
    "revisionHistoryLimit": 10,
    "selector": {
      "matchLabels": {
        "app": "scheduling"
      }
    },
    "strategy": {
      "rollingUpdate": {
        "maxSurge": "25%",
        "maxUnavailable": "25%"
      },
      "type": "RollingUpdate"
    },
    "template": {
      "metadata": {
        "annotations": {
          "kubectl.kubernetes.io/restartedAt": "2026-02-27T05:42:11Z",
          "prometheus.io/path": "/metrics",
          "prometheus.io/port": "9090",
          "prometheus.io/scrape": "true"
        },
        "labels": {
          "app": "scheduling"
        }
      },
      "spec": {
        "containers": [
          {
            "env": [
              {
                "name": "PORT",
                "value": "9008"
              },
              {
                "name": "APP_PORT",
                "value": "9008"
              },
              {
                "name": "APP_HOST",
                "value": "0.0.0.0"
              },
              {
                "name": "LOG_LEVEL",
                "value": "DEBUG"
              },
              {
                "name": "ARANGO_HOST",
                "value": "arangodb-db.dev-ben.svc.cluster.local"
              },
              {
                "name": "WS_REDIS_HOST",
                "value": "redis-db.dev-ben.svc.cluster.local"
              },
              {
                "name": "WS_REDIS_PASSWORD"
              },
              {
                "name": "DEBUG",
                "value": "true"
              },
              {
                "name": "JWT_ALGORITHM",
                "value": "RS256"
              }
            ],
            "envFrom": [
              {
                "configMapRef": {
                  "name": "flowmaster-config"
                }
              },
              {
                "secretRef": {
                  "name": "flowmaster-secrets"
                }
              },
              {
                "configMapRef": {
                  "name": "jwt-rs256-config"
                }
              }
            ],
            "image": "localhost:30500/flowmaster/scheduling-service:ben-dev",
            "imagePullPolicy": "IfNotPresent",
            "lifecycle": {
              "postStart": {
                "exec": {
                  "command": [
                    "python3",
                    "/opt/patches/sched/patch.py"
                  ]
                }
              }
            },
            "name": "scheduling",
            "ports": [
              {
                "containerPort": 9008,
                "protocol": "TCP"
              }
            ],
            "resources": {
              "limits": {
                "cpu": "500m",
                "memory": "512Mi"
              },
              "requests": {
                "cpu": "10m",
                "memory": "64Mi"
              }
            },
            "terminationMessagePath": "/dev/termination-log",
            "terminationMessagePolicy": "File",
            "volumeMounts": [
              {
                "mountPath": "/app/src/main.py",
                "name": "main-patch",
                "subPath": "main.py"
              },
              {
                "mountPath": "/opt/patches/sched",
                "name": "sched-auth-patch-vol"
              }
            ]
          }
        ],
        "dnsPolicy": "ClusterFirst",
        "restartPolicy": "Always",
        "schedulerName": "default-scheduler",
        "securityContext": {},
        "terminationGracePeriodSeconds": 30,
        "volumes": [
          {
            "configMap": {
              "defaultMode": 420,
              "name": "scheduling-main-patch"
            },
            "name": "main-patch"
          },
          {
            "configMap": {
              "defaultMode": 420,
              "name": "sched-auth-rs256-patch"
            },
            "name": "sched-auth-patch-vol"
          }
        ]
