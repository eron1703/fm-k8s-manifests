{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "annotations": {
      "deployment.kubernetes.io/revision": "5",
      "kubectl.kubernetes.io/last-applied-configuration": "{\"apiVersion\":\"apps/v1\",\"kind\":\"Deployment\",\"metadata\":{\"annotations\":{},\"labels\":{\"app\":\"hubs-service\",\"tier\":\"backend\"},\"name\":\"hubs-service\",\"namespace\":\"dev-ben\"},\"spec\":{\"progressDeadlineSeconds\":600,\"replicas\":1,\"revisionHistoryLimit\":10,\"selector\":{\"matchLabels\":{\"app\":\"hubs-service\"}},\"strategy\":{\"rollingUpdate\":{\"maxSurge\":\"25%\",\"maxUnavailable\":\"25%\"},\"type\":\"RollingUpdate\"},\"template\":{\"metadata\":{\"annotations\":{\"kubectl.kubernetes.io/restartedAt\":\"2026-02-24T10:39:10Z\"},\"labels\":{\"app\":\"hubs-service\",\"tier\":\"backend\"}},\"spec\":{\"containers\":[{\"env\":[{\"name\":\"SERVICE_NAME\",\"value\":\"hubs-service\"},{\"name\":\"PORT\",\"value\":\"8022\"},{\"name\":\"ARANGO_HOST\",\"value\":\"arangodb-db.data-ben.svc.cluster.local\"},{\"name\":\"ARANGO_PORT\",\"value\":\"8529\"},{\"name\":\"ARANGO_USER\",\"value\":\"root\"},{\"name\":\"ARANGO_DATABASE\",\"value\":\"flowmaster\"},{\"name\":\"ARANGO_PASSWORD\",\"value\":\"\",\"valueFrom\":{\"secretKeyRef\":{\"key\":\"ARANGO_PASSWORD\",\"name\":\"hubs-service-secrets\"}}},{\"name\":\"JWT_SECRET_KEY\",\"value\":\"\",\"valueFrom\":{\"secretKeyRef\":{\"key\":\"JWT_SECRET_KEY\",\"name\":\"hubs-service-secrets\"}}}],\"image\":\"localhost:30500/flowmaster/hubs-service:integrate\",\"imagePullPolicy\":\"Always\",\"livenessProbe\":{\"failureThreshold\":3,\"httpGet\":{\"path\":\"/health/live\",\"port\":8022,\"scheme\":\"HTTP\"},\"initialDelaySeconds\":15,\"periodSeconds\":30,\"successThreshold\":1,\"timeoutSeconds\":5},\"name\":\"hubs-service\",\"ports\":[{\"containerPort\":8022,\"protocol\":\"TCP\"}],\"readinessProbe\":{\"failureThreshold\":3,\"httpGet\":{\"path\":\"/health/ready\",\"port\":8022,\"scheme\":\"HTTP\"},\"initialDelaySeconds\":10,\"periodSeconds\":10,\"successThreshold\":1,\"timeoutSeconds\":5},\"resources\":{\"limits\":{\"cpu\":\"500m\",\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"50m\",\"memory\":\"128Mi\"}},\"terminationMessagePath\":\"/dev/termination-log\",\"terminationMessagePolicy\":\"File\"}],\"dnsPolicy\":\"ClusterFirst\",\"restartPolicy\":\"Always\",\"schedulerName\":\"default-scheduler\",\"securityContext\":{},\"terminationGracePeriodSeconds\":30}}}}\n"
    },
    "labels": {
      "app": "hubs-service",
      "tier": "backend"
    },
    "name": "hubs-service",
    "namespace": "dev-ben"
  },
  "spec": {
    "progressDeadlineSeconds": 600,
    "replicas": 1,
    "revisionHistoryLimit": 10,
    "selector": {
      "matchLabels": {
        "app": "hubs-service"
      }
    },
    "strategy": {
      "rollingUpdate": {
        "maxSurge": "25%",
        "maxUnavailable": "25%"
      },
      "type": "RollingUpdate"
    },
    "template": {
      "metadata": {
        "annotations": {
          "kubectl.kubernetes.io/restartedAt": "2026-02-24T10:39:10Z"
        },
        "labels": {
          "app": "hubs-service",
          "tier": "backend"
        }
      },
      "spec": {
        "containers": [
          {
            "env": [
              {
                "name": "SERVICE_NAME",
                "value": "hubs-service"
              },
              {
                "name": "PORT",
                "value": "8022"
              },
              {
                "name": "ARANGO_HOST",
                "value": "arangodb-db.dev-ben.svc.cluster.local"
              },
              {
                "name": "ARANGO_PORT",
                "value": "8529"
              },
              {
                "name": "ARANGO_USER",
                "value": "root"
              },
              {
                "name": "ARANGO_DATABASE",
                "value": "flowmaster"
              },
              {
                "name": "ARANGO_PASSWORD",
                "valueFrom": {
                  "secretKeyRef": {
                    "key": "ARANGO_PASSWORD",
                    "name": "hubs-service-secrets"
                  }
                }
              },
              {
                "name": "JWT_SECRET_KEY",
                "valueFrom": {
                  "secretKeyRef": {
                    "key": "JWT_SECRET_KEY",
                    "name": "hubs-service-secrets"
                  }
                }
              }
            ],
            "image": "localhost:30500/flowmaster/hubs-service:ben-dev",
            "imagePullPolicy": "IfNotPresent",
            "livenessProbe": {
              "failureThreshold": 3,
              "httpGet": {
                "path": "/health/live",
                "port": 8022,
                "scheme": "HTTP"
              },
              "initialDelaySeconds": 15,
              "periodSeconds": 30,
              "successThreshold": 1,
              "timeoutSeconds": 5
            },
            "name": "hubs-service",
            "ports": [
              {
                "containerPort": 8022,
                "protocol": "TCP"
              }
            ],
            "readinessProbe": {
              "failureThreshold": 3,
              "httpGet": {
                "path": "/health/ready",
                "port": 8022,
                "scheme": "HTTP"
              },
              "initialDelaySeconds": 10,
              "periodSeconds": 10,
              "successThreshold": 1,
              "timeoutSeconds": 5
            },
            "resources": {
              "limits": {
                "cpu": "500m",
                "memory": "512Mi"
              },
              "requests": {
                "cpu": "50m",
                "memory": "128Mi"
              }
            },
            "terminationMessagePath": "/dev/termination-log",
            "terminationMessagePolicy": "File"
          }
        ],
        "dnsPolicy": "ClusterFirst",
        "restartPolicy": "Always",
        "schedulerName": "default-scheduler",
        "securityContext": {},
        "terminationGracePeriodSeconds": 30
      }
    }
  }
}