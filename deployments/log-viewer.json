{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "annotations": {
      "deployment.kubernetes.io/revision": "6",
      "kubectl.kubernetes.io/last-applied-configuration": "{\"apiVersion\":\"apps/v1\",\"kind\":\"Deployment\",\"metadata\":{\"annotations\":{},\"labels\":{\"app\":\"log-viewer\",\"component\":\"monitoring\"},\"name\":\"log-viewer\",\"namespace\":\"dev-ben\"},\"spec\":{\"progressDeadlineSeconds\":600,\"replicas\":1,\"revisionHistoryLimit\":10,\"selector\":{\"matchLabels\":{\"app\":\"log-viewer\"}},\"strategy\":{\"rollingUpdate\":{\"maxSurge\":\"25%\",\"maxUnavailable\":\"25%\"},\"type\":\"RollingUpdate\"},\"template\":{\"metadata\":{\"annotations\":{\"kubectl.kubernetes.io/restartedAt\":\"2026-02-25T12:24:04Z\"},\"labels\":{\"app\":\"log-viewer\",\"component\":\"monitoring\"}},\"spec\":{\"containers\":[{\"env\":[{\"name\":\"ARANGO_HOST\",\"value\":\"arangodb-db.data-ben.svc.cluster.local\"},{\"name\":\"ARANGO_PORT\",\"value\":\"8529\"},{\"name\":\"ARANGO_USER\",\"value\":\"root\"},{\"name\":\"ARANGO_PASSWORD\",\"value\":\"flowmaster25!\"},{\"name\":\"ARANGO_DB_NAME\",\"value\":\"flowmaster\"},{\"name\":\"PYTHONPATH\",\"value\":\"/app:/opt/flowmaster/flowmaster-logging\"}],\"image\":\"localhost:30500/flowmaster-log-viewer:integrate\",\"imagePullPolicy\":\"Never\",\"livenessProbe\":{\"failureThreshold\":3,\"httpGet\":{\"path\":\"/health\",\"port\":3099,\"scheme\":\"HTTP\"},\"initialDelaySeconds\":30,\"periodSeconds\":10,\"successThreshold\":1,\"timeoutSeconds\":1},\"name\":\"log-viewer\",\"ports\":[{\"containerPort\":3099,\"name\":\"http\",\"protocol\":\"TCP\"}],\"readinessProbe\":{\"failureThreshold\":3,\"httpGet\":{\"path\":\"/health\",\"port\":3099,\"scheme\":\"HTTP\"},\"initialDelaySeconds\":10,\"periodSeconds\":5,\"successThreshold\":1,\"timeoutSeconds\":1},\"resources\":{},\"terminationMessagePath\":\"/dev/termination-log\",\"terminationMessagePolicy\":\"File\"}],\"dnsPolicy\":\"ClusterFirst\",\"restartPolicy\":\"Always\",\"schedulerName\":\"default-scheduler\",\"securityContext\":{},\"terminationGracePeriodSeconds\":30}}}}\n"
    },
    "labels": {
      "app": "log-viewer",
      "component": "monitoring"
    },
    "name": "log-viewer",
    "namespace": "dev-ben"
  },
  "spec": {
    "progressDeadlineSeconds": 600,
    "replicas": 1,
    "revisionHistoryLimit": 10,
    "selector": {
      "matchLabels": {
        "app": "log-viewer"
      }
    },
    "strategy": {
      "rollingUpdate": {
        "maxSurge": "25%",
        "maxUnavailable": "25%"
      },
      "type": "RollingUpdate"
    },
    "template": {
      "metadata": {
        "annotations": {
          "kubectl.kubernetes.io/restartedAt": "2026-02-25T12:24:04Z"
        },
        "labels": {
          "app": "log-viewer",
          "component": "monitoring"
        }
      },
      "spec": {
        "containers": [
          {
            "env": [
              {
                "name": "ARANGO_HOST",
                "value": "arangodb-db.dev-ben.svc.cluster.local"
              },
              {
                "name": "ARANGO_PORT",
                "value": "8529"
              },
              {
                "name": "ARANGO_USER",
                "value": "root"
              },
              {
                "name": "ARANGO_PASSWORD",
                "value": "flowmaster25!"
              },
              {
                "name": "ARANGO_DB_NAME",
                "value": "flowmaster"
              },
              {
                "name": "PYTHONPATH",
                "value": "/app:/opt/flowmaster/flowmaster-logging"
              }
            ],
            "image": "localhost:30500/flowmaster-log-viewer:ben-dev",
            "imagePullPolicy": "IfNotPresent",
            "livenessProbe": {
              "failureThreshold": 3,
              "httpGet": {
                "path": "/health",
                "port": 3099,
                "scheme": "HTTP"
              },
              "initialDelaySeconds": 30,
              "periodSeconds": 10,
              "successThreshold": 1,
              "timeoutSeconds": 1
            },
            "name": "log-viewer",
            "ports": [
              {
                "containerPort": 3099,
                "name": "http",
                "protocol": "TCP"
              }
            ],
            "readinessProbe": {
              "failureThreshold": 3,
              "httpGet": {
                "path": "/health",
                "port": 3099,
                "scheme": "HTTP"
              },
              "initialDelaySeconds": 10,
              "periodSeconds": 5,
              "successThreshold": 1,
              "timeoutSeconds": 1
            },
            "resources": {},
            "terminationMessagePath": "/dev/termination-log",
            "terminationMessagePolicy": "File"
          }
        ],
        "dnsPolicy": "ClusterFirst",
        "restartPolicy": "Always",
        "schedulerName": "default-scheduler",
        "securityContext": {},
        "terminationGracePeriodSeconds": 30
      }
    }
  }
}